generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String @id @default(uuid())
  username String @unique
  password String
  phone    String @unique
  role     Role   @default(CLIENT)
}

enum Role {
  CLIENT
  ADMIN
}
