generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String @id @default(uuid())
  username String @unique
  password String
  phone    String @unique
  role     Role   @default(CLIENT)
}

enum Role {
  CLIENT
  ADMIN
}


model Service {
  id          String   @id @default(uuid())
  name        String   @unique
  price       String   @default("0")
  time        String   @default("0")
  category    Category @default(GENERAL)
  state       Boolean   @default(true)
  discount    String   @default("0")
  position    Position @default(TODOLOGO)

}

enum Category {
  GENERAL
}

// TODO: ¿Que pasa si X empleado solo puede dar Y servicio?
model Employee {
  id       String @id @default(uuid())
  name     String
  firstLastName String
  secondLastName String
  position Position @default(TODOLOGO)
  state    Boolean @default(true)
  createdAt DateTime @default(now())
  phone    String @unique
  salary   String @default("0")
}

enum Position {
  TODOLOGO
  PELUQUERO
  MANICURISTA
}

model Appointment {
  id String @id @default(uuid())
  serviceId String
  employeeId String
  startTime DateTime
  customerName String
  customerNumber String
  state AppointmentState @default(SCHEDULED)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  observation String
}

enum AppointmentState {
  SCHEDULED
  CANCELLED
  FINISHED
}